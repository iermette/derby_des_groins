# ── PostgreSQL ────────────────────────────────────────────────────────
POSTGRES_PASSWORD=derby_secret

# ── Flask ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-random-string-in-production
FLASK_ENV=production
FLASK_DEBUG=false

# ── Derby des Groins ──────────────────────────────────────────────────
DERBY_TIMEZONE=Europe/Paris
# DERBY_DISABLE_SCHEDULER=0
# DERBY_FORCE_SCHEDULER=1   (set automatiquement dans docker-compose)

# ── Serveur ───────────────────────────────────────────────────────────
PORT=5001
